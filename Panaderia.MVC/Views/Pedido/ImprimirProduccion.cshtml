@model Panaderia.MVC.Models.ImprimirProduccionViewModel
@using Panaderia.Models.Enums
@using Panaderia.Models.DTOs
@using System.Globalization
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Plan de producción — @Model.Fecha.ToString("dd/MM/yyyy")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-size: 13px; }
        .grid-recetas {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .receta-card {
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 4px;
            font-size: 12px;
            break-inside: avoid;
        }
        @@media print {
            .no-print { display: none !important; }
            .grid-recetas {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }
            .receta-card {
                break-inside: avoid;
            }
            .receta-card:nth-child(4n) {
                break-after: page;
            }
        }
    </style>
</head>
<body onload="window.print()">
    <button onclick="window.print()" class="no-print btn btn-sm btn-secondary mb-3">Imprimir</button>

    <h4>Plan de producción — @Model.Fecha.ToString("dd/MM/yyyy")</h4>

    @if (!Model.Items.Any())
    {
        <p>No hay productos con receta para producir.</p>
    }
    else
    {
        <div class="grid-recetas">
            @foreach (var item in Model.Items)
            {
                <div class="receta-card">
                    <h5 style="margin:0 0 4px 0; font-size:14px;">@item.NombreProducto</h5>
                    <p style="margin:0 0 6px 0; font-size:11px; color:#555;">
                        Producir: <strong>@item.CantidadUnidades u.</strong>
                        (@item.VecesReceta.ToString("0.##")× lote base de @item.Receta.TamanioLote u.)
                    </p>
                    <table style="width:100%; border-collapse:collapse; font-size:11px;">
                        <thead>
                            <tr>
                                <th style="border:1px solid #ccc; padding:3px 6px; background:#f0f0f0; text-align:left;">Ingrediente</th>
                                <th style="border:1px solid #ccc; padding:3px 6px; background:#f0f0f0;">Unidad</th>
                                <th style="border:1px solid #ccc; padding:3px 6px; background:#f0f0f0;">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var det in item.Receta.Detalles.Where(d => d.Insumo != null))
                            {
                                var unidadStr = det.Insumo.UnidadBase switch
                                {
                                    UnidadMedida.Gramos     => "g",
                                    UnidadMedida.Mililitros => "ml",
                                    UnidadMedida.Unidades   => "u",
                                    _                       => det.Insumo.UnidadBase.ToString()
                                };
                                decimal cantidadDet = 0m;
                                if (det.PorcentajePanadero.HasValue && item.Receta.SumaPorcentajes > 0)
                                    cantidadDet = (item.Receta.TamanioLote * item.Receta.PesoUnitario
                                                   / item.Receta.SumaPorcentajes)
                                                  * det.PorcentajePanadero.Value * item.VecesReceta;
                                else if (det.CantidadFija.HasValue)
                                    cantidadDet = det.CantidadFija.Value * item.CantidadUnidades;
                                <tr>
                                    <td style="border:1px solid #ccc; padding:3px 6px;">@det.Insumo.Nombre</td>
                                    <td style="border:1px solid #ccc; padding:3px 6px; text-align:center;">@unidadStr</td>
                                    <td style="border:1px solid #ccc; padding:3px 6px; text-align:right;">@cantidadDet.ToString("0.###", CultureInfo.InvariantCulture)</td>
                                </tr>
                            }
                            @foreach (var det in item.Receta.Detalles.Where(d => d.IdSubReceta.HasValue && d.SubReceta != null))
                            {
                                decimal cantidadSr = 0m;
                                if (det.PorcentajePanadero.HasValue && item.Receta.SumaPorcentajes > 0)
                                {
                                    cantidadSr = (item.Receta.TamanioLote * item.Receta.PesoUnitario
                                                  / item.Receta.SumaPorcentajes)
                                                 * det.PorcentajePanadero.Value * item.VecesReceta;
                                }
                                <tr style="background-color: #fff8e1;">
                                    <td style="border:1px solid #ccc; padding:3px 6px;">⟳ @det.SubReceta!.Nombre</td>
                                    <td style="border:1px solid #ccc; padding:3px 6px; text-align:center;">g</td>
                                    <td style="border:1px solid #ccc; padding:3px 6px; text-align:right;">@cantidadSr.ToString("0.###", CultureInfo.InvariantCulture)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <p style="margin:6px 0 0 0; font-size:11px;">
                        <strong>Peso masa:</strong>
                        @((item.Receta.TamanioLote * item.Receta.PesoUnitario * item.VecesReceta)
                            .ToString("0.###", CultureInfo.InvariantCulture)) g
                        &nbsp;|&nbsp;
                        <strong>Rinde:</strong> @item.CantidadUnidades u.
                    </p>
                </div>
            }
        </div>
    }

    @if (Model.SubRecetas.Any())
    {
        <div style="margin-top: 20px;">
            <h4 style="margin-bottom: 10px; font-size: 14px; border-bottom: 1px solid #ccc; padding-bottom: 4px;">
                Preparaciones previas
            </h4>
            <div class="grid-recetas">
                @foreach (var sr in Model.SubRecetas)
                {
                    <div class="receta-card">
                        <h5 style="margin:0 0 4px 0; font-size:14px;">@sr.Nombre</h5>
                        <p style="margin:0 0 6px 0; font-size:11px; color:#555;">
                            Total con margen: <strong>@sr.TotalGramos.ToString("0.#") g</strong>
                        </p>
                        <table style="width:100%; border-collapse:collapse; font-size:11px;">
                            <thead>
                                <tr>
                                    <th style="border:1px solid #ccc; padding:3px 6px; background:#f0f0f0; text-align:left;">Ingrediente</th>
                                    <th style="border:1px solid #ccc; padding:3px 6px; background:#f0f0f0; text-align:right;">Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ing in sr.Ingredientes)
                                {
                                    <tr>
                                        <td style="border:1px solid #ccc; padding:3px 6px;">@ing.NombreInsumo</td>
                                        <td style="border:1px solid #ccc; padding:3px 6px; text-align:right;">
                                            @ing.Cantidad.ToString("0.#") @ing.Unidad
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</body>
</html>
