@using Panaderia.Models.DTOs
@model Panaderia.MVC.Models.ProduccionViewModel

@{
    ViewData["Title"] = "Producción";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 fw-bold titulo-pagina mb-1">Dashboard de Producción</h1>
    <a asp-action="Index" class="btn btn-mv-primary">Volver</a>
</div>

<div style="max-width: 900px;">
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card card-custom p-4">
                <h5 class="fw-bold mb-3">Totales por Producto</h5>
                @if (!Model.PorProducto.Any())
                {
                    <p class="text-muted">No hay pedidos pendientes de producción.</p>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-end">Cantidad a producir</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PorProducto)
                            {
                                <tr>
                                    <td>@item.NombreProducto</td>
                                    <td class="text-end fw-bold">@item.CantidadTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="card card-custom p-4">
                <h5 class="fw-bold mb-3">Totales por Tipo de Bolsa</h5>
                @if (!Model.PorBolsa.Any())
                {
                    <p class="text-muted">No hay pedidos pendientes de producción.</p>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Tipo de bolsa</th>
                                <th class="text-end">Cantidad total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PorBolsa)
                            {
                                <tr>
                                    <td>@item.Bolsa</td>
                                    <td class="text-end fw-bold">@item.CantidadTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
