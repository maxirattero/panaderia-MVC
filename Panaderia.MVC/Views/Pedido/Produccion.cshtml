@using Panaderia.Models.DTOs
@model Panaderia.MVC.Models.ProduccionViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Producción";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 fw-bold titulo-pagina mb-1">Dashboard de Producción</h1>
    <div class="d-flex gap-2">
        <a asp-action="PlanificarAmasadas"
           class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
            <span class="material-symbols-outlined">blender</span>Planificar amasadas
        </a>
        <a asp-action="ImprimirProduccion" target="_blank"
           class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
            <span class="material-symbols-outlined">print</span>Imprimir plan
        </a>
        <a asp-action="Index" class="btn btn-mv-primary">Volver</a>
    </div>
</div>

<div style="max-width: 900px;">
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card card-custom p-4">
                <h5 class="fw-bold mb-3">Totales por Producto</h5>
                @if (!Model.PorProducto.Any())
                {
                    <p class="text-muted">No hay pedidos pendientes de producción.</p>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-end">Cantidad a producir</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PorProducto)
                            {
                                <tr>
                                    <td>@item.NombreProducto</td>
                                    <td class="text-end fw-bold">@item.CantidadTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="card card-custom p-4">
                <h5 class="fw-bold mb-3">Totales por Tipo de Bolsa</h5>
                @if (!Model.PorBolsa.Any())
                {
                    <p class="text-muted">No hay pedidos pendientes de producción.</p>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Tipo de bolsa</th>
                                <th class="text-end">Cantidad total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PorBolsa)
                            {
                                <tr>
                                    <td>@item.Bolsa</td>
                                    <td class="text-end fw-bold">@item.CantidadTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @if (Model.PorSubReceta.Any() || Model.TotalAgua > 0)
    {
        <div class="row g-4 mt-0">
            @if (Model.TotalAgua > 0)
            {
                <div class="col-md-6">
                    <div class="card card-custom p-4">
                        <h5 class="fw-bold mb-1">
                            <span class="material-symbols-outlined align-middle me-1">water_drop</span>Agua
                        </h5>
                        <p class="mb-0 mt-2">
                            Total necesario:
                            <strong class="fs-4">@Model.TotalAgua.ToString("N0") g</strong>
                        </p>
                    </div>
                </div>
            }
            @foreach (var sr in Model.PorSubReceta)
            {
                <div class="col-md-6">
                    <div class="card card-custom p-4">
                        <h5 class="fw-bold mb-1">@sr.Nombre</h5>
                        <p class="text-muted small mb-3">
                            Total con margen: <strong>@sr.TotalGramos.ToString("0.#") g</strong>
                        </p>
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Ingrediente</th>
                                    <th class="text-end">Cantidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ing in sr.Ingredientes)
                                {
                                    <tr>
                                        <td>@ing.NombreInsumo</td>
                                        <td class="text-end fw-bold">
                                            @ing.Cantidad.ToString("0.#") @ing.Unidad
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        var msgs = TempData["Warning"]!.ToString()!.Split('|');
        <div class="alert alert-warning alert-dismissible fade show mt-4" role="alert">
            @foreach (var msg in msgs) { <div>@msg</div> }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.ItemsSeleccionables.Any())
    {
        <div class="card card-custom p-4 mt-4">
            <h5 class="fw-semibold mb-3">Confirmar producción</h5>
            <form asp-action="ConfirmarProduccion" method="post">
                @Html.AntiForgeryToken()
                <div class="table-responsive mb-3">
                    <table class="table table-sm align-middle mb-0">
                        <thead style="background-color: #cebaac; color: #281714;">
                            <tr>
                                <th style="width:40px;"></th>
                                <th>Producto</th>
                                <th style="width:140px;">Cantidad a producir</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.ItemsSeleccionables.Count; i++)
                            {
                                var item = Model.ItemsSeleccionables[i];
                                <tr>
                                    <td>
                                        <input type="hidden" name="ItemsSeleccionables[@i].IdProducto" value="@item.IdProducto" />
                                        <input type="hidden" name="ItemsSeleccionables[@i].IdReceta" value="@item.IdReceta" />
                                        <input type="hidden" name="ItemsSeleccionables[@i].NombreProducto" value="@item.NombreProducto" />
                                        <input type="hidden" name="ItemsSeleccionables[@i].CantidadSugerida"
                                               value="@item.CantidadSugerida.ToString(CultureInfo.InvariantCulture)" />
                                        <input type="checkbox" name="ItemsSeleccionables[@i].Seleccionado" value="true"
                                               class="form-check-input" @(item.Seleccionado ? "checked" : "") />
                                        <input type="hidden" name="ItemsSeleccionables[@i].Seleccionado" value="false" />
                                    </td>
                                    <td>@item.NombreProducto</td>
                                    <td>
                                        <input type="number"
                                               name="ItemsSeleccionables[@i].CantidadAProducir"
                                               class="form-control form-control-sm"
                                               style="width:90px"
                                               lang="en" step="1" min="1"
                                               value="@item.CantidadAProducir.ToString(CultureInfo.InvariantCulture)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button type="submit" class="btn btn-mv-primary d-inline-flex align-items-center gap-2">
                    <span class="material-symbols-outlined">check_circle</span>Confirmar producción
                </button>
            </form>
        </div>
    }
</div>
