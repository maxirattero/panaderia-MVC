@model IEnumerable<Panaderia.Models.Entities.Pedido>
@{
    Layout = null;
    bool conDetalles = ViewBag.ConDetalles == true;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pedidos Pendientes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-size: 12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 4px 8px; }
        th { background-color: #f0f0f0; }
        @@media print {
            .no-print { display: none !important; }
            body { font-size: 12px; }
        }
    </style>
</head>
<body onload="window.print()">
    <button onclick="window.print()" class="no-print btn btn-sm btn-secondary mb-3">Imprimir</button>

    <h4>Pedidos Pendientes — @DateTime.Now.ToString("dd/MM/yyyy")@(conDetalles ? " (con detalles)" : "")</h4>

    @if (!Model.Any())
    {
        <p>No hay pedidos pendientes.</p>
    }
    else if (!conDetalles)
    {
        <table>
            <thead>
                <tr>
                    <th>Cliente</th><th>Dirección</th><th>Notas</th><th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Cliente.NombreCompleto</td>
                        <td>@p.Cliente.Direccion</td>
                        <td>@p.Notas</td>
                        <td>@p.MontoTotal.ToString("C", new System.Globalization.CultureInfo("es-AR"))</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        @foreach (var p in Model)
        {
            <div style="margin-bottom: 1rem;">
                <div style="text-align: center; font-size: 16px;">
                <strong>@p.Cliente.NombreCompleto</strong> — @p.Cliente.Direccion - Tel: @p.Cliente.Telefono @(string.IsNullOrWhiteSpace(p.Notas) ? "" : $" | Notas: {p.Notas}")
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Producto</th><th>Cant.</th><th>Bolsa</th>
                            <th>Precio unit.</th><th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in p.Detalles)
                        {
                            <tr>
                                <td>@d.Producto.NombreVisible</td>
                                <td>@d.Cantidad</td>
                                <td>@d.Bolsa</td>
                                <td>@d.PrecioUnitario.ToString("C", new System.Globalization.CultureInfo("es-AR"))</td>
                                <td>@((d.Cantidad * d.PrecioUnitario).ToString("C", new System.Globalization.CultureInfo("es-AR")))</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div style="text-align: right; margin-top: 4px;">
                    <strong>Total: @p.MontoTotal.ToString("C", new System.Globalization.CultureInfo("es-AR"))</strong>
                </div>
            </div>
            <hr />
        }
        <div style="text-align: right;">
            <strong>Total general: @Model.Sum(p => p.MontoTotal).ToString("C", new System.Globalization.CultureInfo("es-AR"))</strong>
        </div>
    }
</body>
</html>
