@using Panaderia.Models.Entities
@using Panaderia.Models.Enums
@model PedidoViewModel

@{
    ViewData["Title"] = "Nuevo Pedido";
}

<div style="max-width: 1200px;">
<div class="mb-4">
    <h1 class="display-6 fw-bold titulo-pagina mb-1">Nuevo Pedido</h1>
    <p class="text-muted">Completa la información para registrar un nuevo pedido.</p>
</div>

<div class="card card-custom p-4 mb-4">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="IdCliente" class="form-label small fw-bold text-muted">Cliente</label>
                <select asp-for="IdCliente" class="form-select">
                    <option value="">-- Seleccionar cliente --</option>
                    @foreach (var c in (IEnumerable<Cliente>)ViewBag.Clientes)
                    {
                        <option value="@c.Id" data-revendedor="@c.Revendedor.ToString().ToLower()">
                            @c.NombreCompleto
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="FechaEntrega" class="form-label small fw-bold text-muted">Fecha de entrega</label>
                <input asp-for="FechaEntrega" type="date" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="Notas" class="form-label small fw-bold text-muted">Notas</label>
                <textarea asp-for="Notas" class="form-control"></textarea>
            </div>
        </div>

        <h4 class="font-literata fw-bold mt-4 mb-3">Productos</h4>
        <table class="table" id="tablaDetalles">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th style="width: 80px;">Cant.</th>
                    <th style="width: 130px;">Bolsa</th>
                    <th style="width: 160px;">Empaque</th>
                    <th style="width: 80px;" class="text-center">Etiqueta</th>
                    <th style="width: 100px;">Subtotal</th>
                    <th style="width: 50px;"></th>
                </tr>
            </thead>
            <tbody id="detallesBody">
            </tbody>
        </table>

        <button type="button" class="btn btn-mv-primary mb-3" id="btnAgregar">+ Agregar producto</button>

        <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-5 pt-4 border-top">
            <button type="submit" class="btn btn-mv-primary d-flex align-items-center justify-content-center gap-2">
                <span class="material-symbols-outlined">save</span>Guardar pedido
            </button>
            <a asp-action="Index" class="btn btn-mv-primary">Cancelar</a>
        </div>
    </form>
</div>
</div>

<template id="filaTemplate">
    <tr>
        <td data-label="Producto">
            <select name="__PROD__" class="form-select prod-select" required>
                <option value="">-- Producto --</option>
                @foreach (var p in (IEnumerable<Producto>)ViewBag.Productos)
                {
                    <option value="@p.Id"
                            data-final="@p.PrecioFinal.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                            data-reventa="@p.PrecioReventa.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                        @p.NombreVisible
                    </option>
                }
            </select>
        </td>
        <td data-label="Cantidad">
            <input name="__CANT__" type="number" min="1" placeholder="Cant." class="form-control cant-input" required />
        </td>
        <td data-label="Bolsa">
            <select name="__BOLSA__" class="form-select bolsa-select" asp-items="Html.GetEnumSelectList<TipoBolsa>()"></select>
        </td>
        <td data-label="Empaque">
            <select name="__EMPAQUE__" class="form-select empaque-select" required>
                <option value="">Empaque...</option>
                @foreach (var e in (IEnumerable<Insumo>)ViewBag.Empaques)
                {
                    <option value="@e.Id">@e.Nombre</option>
                }
            </select>
        </td>
        <td data-label="Etiqueta" class="text-center align-middle">
            <input name="__ETIQUETA__" type="checkbox" class="form-check-input etiqueta-check" value="true" />
        </td>
        <td data-label="Subtotal" class="subtotal">$0</td>
        <td>
            <button type="button" class="btn btn-sm btn-danger btnQuitar">&#x2715;</button>
        </td>
    </tr>
</template>

@section Scripts {
    <script>
        (function () {
            const tbody = document.getElementById('detallesBody');
            const template = document.getElementById('filaTemplate');
            const btnAgregar = document.getElementById('btnAgregar');
            const clienteSelect = document.getElementById('IdCliente');

            function clienteEsRevendedor() {
                const opt = clienteSelect.options[clienteSelect.selectedIndex];
                return opt && opt.dataset.revendedor === 'true';
            }

            function recalcularFila(tr) {
                const prodSelect = tr.querySelector('.prod-select');
                const cantInput = tr.querySelector('.cant-input');
                const subtotalCell = tr.querySelector('.subtotal');
                const opt = prodSelect.options[prodSelect.selectedIndex];

                let precio = 0;
                if (opt && opt.value) {
                    precio = clienteEsRevendedor()
                        ? parseFloat(opt.dataset.reventa)
                        : parseFloat(opt.dataset.final);
                }
                const cant = parseInt(cantInput.value) || 0;
                subtotalCell.textContent = '$' + (precio * cant).toFixed(2);
            }

            function reindexar() {
                tbody.querySelectorAll('tr').forEach((tr, i) => {
                    tr.querySelector('.prod-select').name    = `Detalles[${i}].IdProducto`;
                    tr.querySelector('.cant-input').name     = `Detalles[${i}].Cantidad`;
                    tr.querySelector('.bolsa-select').name   = `Detalles[${i}].Bolsa`;
                    tr.querySelector('.empaque-select').name = `Detalles[${i}].IdEmpaque`;
                    tr.querySelector('.etiqueta-check').name = `Detalles[${i}].LlevaEtiqueta`;
                });
            }

            function agregarFila() {
                const tr = template.content.cloneNode(true).querySelector('tr');
                tbody.appendChild(tr);
                reindexar();

                tr.querySelector('.prod-select').addEventListener('change', () => recalcularFila(tr));
                tr.querySelector('.cant-input').addEventListener('input', () => recalcularFila(tr));
                tr.querySelector('.btnQuitar').addEventListener('click', () => {
                    tr.remove();
                    reindexar();
                });
            }

            btnAgregar.addEventListener('click', agregarFila);

            clienteSelect.addEventListener('change', () => {
                tbody.querySelectorAll('tr').forEach(recalcularFila);
            });

            agregarFila();
        })();
    </script>
}
