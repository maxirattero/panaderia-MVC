@model Panaderia.MVC.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Masa Viva — Iniciar sesión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --mv-primary: #281714;
            --mv-secondary: #cebaac;
            --mv-background: #f5efe9;
            --mv-accent: #d4a574;
        }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--mv-background);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(40, 23, 20, 0.08);
            padding: 2.5rem;
            width: 100%;
            max-width: 400px;
        }
        .login-title {
            font-family: 'Literata', serif;
            color: var(--mv-primary);
            font-weight: 700;
        }
        .btn-login {
            background-color: var(--mv-primary);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 0.6rem;
            font-weight: 600;
            width: 100%;
        }
        .btn-login:hover {
            background-color: #3d2520;
            color: white;
        }
        .form-control:focus {
            border-color: var(--mv-accent);
            box-shadow: 0 0 0 0.2rem rgba(212, 165, 116, 0.25);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h1 class="login-title fs-3">Masa Viva</h1>
            <p class="text-muted small">Iniciá sesión para continuar</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small fw-bold text-muted">Email</label>
                <input asp-for="Email" type="email" class="form-control" autofocus />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label small fw-bold text-muted">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" />
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label small">Recordarme</label>
            </div>

            <button type="submit" class="btn btn-login">Iniciar sesión</button>
        </form>
    </div>
</body>
</html>
