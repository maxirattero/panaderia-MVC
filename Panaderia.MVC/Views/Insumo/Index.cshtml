@model IEnumerable<Panaderia.Models.Entities.Insumo>
@using Panaderia.Models.Enums
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Insumos";
    var cultura = new System.Globalization.CultureInfo("es-AR");
}
    <div class="row align-items-end mb-5 gy-4">
        <div class="col-md-7">
            <h1 class="display-6 fw-bold titulo-pagina mb-1">Insumos</h1>
            <p class="text-secondary m-0">Administrá las materias primas e insumos de la panadería.</p>
        </div>
        <div class="col-md-5 text-md-end">
            <a asp-action="Create" class="btn btn-mv-primary d-inline-flex align-items-center gap-2 shadow">
                <span class="material-symbols-outlined">add</span>
                Nuevo Insumo
            </a>
        </div>
    </div>

    <div class="card-custom p-3 mb-4">
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">
                        <span class="material-symbols-outlined text-secondary">filter_list</span>
                    </span>
                    <input id="filtroTexto" class="form-control border-start-0 ps-0" placeholder="Buscar insumo..." type="text" />
                </div>
            </div>
            <div class="col-12 d-flex align-items-center gap-2 flex-wrap">
                <button id="pilTodos"     class="pill-filtro activo" onclick="setPill('todos')">Todos</button>
                <button id="pilActivos"   class="pill-filtro"        onclick="setPill('activos')">Activos</button>
                <button id="pilInactivos" class="pill-filtro"        onclick="setPill('inactivos')">Inactivos</button>
                <button id="pilBajoStock" class="pill-filtro"        onclick="setPill('bajostock')">Bajo stock</button>
                <span id="contadorVisible" class="text-secondary small ms-2"></span>
            </div>
        </div>
    </div>

    <div class="card card-custom overflow-hidden">
        <div class="table-responsive">
            <table class="table table-custom table-hover m-0">
                <thead>
                    <tr>
                        <th class="d-md-none"></th>
                        <th>Nombre</th>
                        <th class="d-none d-md-table-cell">Tipo</th>
                        <th class="d-none d-md-table-cell">Unidad</th>
                        <th class="d-none d-md-table-cell">Precio Compra</th>
                        <th class="d-none d-md-table-cell">Rendimiento</th>
                        <th class="d-none d-md-table-cell">Costo/Unidad</th>
                        <th class="d-none d-md-table-cell">Proveedor</th>
                        <th>Estado</th>
                        <th>Stock actual</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">No hay insumos registrados.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var insumo in Model)
                        {
                            var sufijo = insumo.UnidadBase switch
                            {
                                UnidadMedida.Gramos => "g",
                                UnidadMedida.Mililitros => "ml",
                                UnidadMedida.Unidades => "u",
                                _ => ""
                            };
                            var tipoBadgeClass = insumo.TipoInsumo switch
                            {
                                TipoInsumo.Empaque  => "bg-info text-dark",
                                TipoInsumo.Etiqueta => "bg-warning text-dark",
                                _                    => "bg-secondary"
                            };
                            var tipoLabel = insumo.TipoInsumo switch
                            {
                                TipoInsumo.Empaque  => "Empaque",
                                TipoInsumo.Etiqueta => "Etiqueta",
                                _                    => "Ingrediente"
                            };
                            var stockStr = insumo.StockActual % 1 == 0
                                ? insumo.StockActual.ToString("0")
                                : insumo.StockActual.ToString("0.###");
                            var stockLabel = $"{stockStr} {sufijo}";
                            var esBajoStock = insumo.StockMinimo.HasValue
                                && insumo.StockActual <= insumo.StockMinimo.Value;
                            <tr class="@(!insumo.Activo ? "opacity-75" : "")"
                                data-busqueda="@($"{insumo.Nombre} {insumo.Proveedor?.Nombre}").ToLower()"
                                data-activo="@insumo.Activo.ToString().ToLower()"
                                data-bajostock="@esBajoStock.ToString().ToLower()">
                                <td class="d-md-none">
                                    <button class="btn btn-sm btn-outline-secondary" type="button"
                                            data-bs-toggle="collapse" data-bs-target="#detalle-insumo-@insumo.Id">
                                        <span class="material-symbols-outlined">expand_more</span>
                                    </button>
                                </td>
                                <td class="fw-bold">@insumo.Nombre</td>
                                <td class="d-none d-md-table-cell">
                                    <span class="badge @tipoBadgeClass">@tipoLabel</span>
                                </td>
                                <td class="d-none d-md-table-cell">@insumo.UnidadBase</td>
                                <td class="d-none d-md-table-cell">@insumo.PrecioCompra.ToString("C", cultura)</td>
                                <td class="d-none d-md-table-cell">@insumo.CantidadRendimiento.ToString("N0") @sufijo</td>
                                <td class="d-none d-md-table-cell">@(insumo.CostoPorUnidadBase.ToString("C", cultura))/@sufijo</td>
                                <td class="d-none d-md-table-cell text-secondary">@(insumo.Proveedor?.Nombre ?? "—")</td>
                                <td>
                                    @if (insumo.Activo)
                                    {
                                        <span class="status-badge status-active">
                                            <span class="dot" style="background-color: var(--mv-success);"></span>
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">
                                            <span class="dot" style="background-color: var(--mv-error);"></span>
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (esBajoStock)
                                    {
                                        <span class="badge bg-warning text-dark">@stockLabel</span>
                                    }
                                    else
                                    {
                                        @stockLabel
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@insumo.Id"
                                           class="btn btn-sm btn-outline-success" title="Editar">
                                            <span class="material-symbols-outlined">edit</span>
                                        </a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                title="Eliminar"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalEliminar"
                                                data-nombre="@insumo.Nombre"
                                                data-delete-url="@Url.Action("Delete", "Insumo", new { id = insumo.Id })"
                                                data-token="@Antiforgery.GetAndStoreTokens(Context).RequestToken">
                                            <span class="material-symbols-outlined">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr class="collapse d-md-none" id="detalle-insumo-@insumo.Id">
                                <td colspan="5" class="bg-light bg-opacity-25">
                                    <div class="d-flex flex-column gap-1 small">
                                        <div><span class="fw-bold">Tipo:</span> <span class="badge @tipoBadgeClass">@tipoLabel</span></div>
                                        <div><span class="fw-bold">Unidad:</span> @insumo.UnidadBase</div>
                                        <div><span class="fw-bold">Precio compra:</span> @insumo.PrecioCompra.ToString("C", cultura)</div>
                                        <div><span class="fw-bold">Rendimiento:</span> @insumo.CantidadRendimiento.ToString("N0") @sufijo</div>
                                        <div><span class="fw-bold">Costo/unidad:</span> @(insumo.CostoPorUnidadBase.ToString("C", cultura))/@sufijo</div>
                                        <div><span class="fw-bold">Proveedor:</span> @(insumo.Proveedor?.Nombre ?? "—")</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

@await Html.PartialAsync("_ModalEliminar")

@section Scripts {
    <script>
        document.getElementById('modalEliminar').addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('modalEliminarNombre').textContent = button.getAttribute('data-nombre');
            document.getElementById('formEliminar').action = button.getAttribute('data-delete-url');
        });
    </script>
    <script>
        (function () {
            const inputTexto = document.getElementById('filtroTexto');
            const contador   = document.getElementById('contadorVisible');
            const filas      = document.querySelectorAll('table tbody > tr:not(.collapse)');
            let filtroTipo   = 'todos';

            function normalizar(str) {
                return (str || '')
                    .normalize('NFD')
                    .replace(/[̀-ͯ]/g, '')
                    .toLowerCase();
            }

            function filtrar() {
                const texto = normalizar(inputTexto.value);
                let visibles = 0;

                filas.forEach(tr => {
                    const busqueda  = normalizar(tr.dataset.busqueda);
                    const activo    = tr.dataset.activo;
                    const bajostock = tr.dataset.bajostock;

                    const okTexto = texto === '' || busqueda.includes(texto);
                    const okTipo  = filtroTipo === 'todos'
                        || (filtroTipo === 'activos'    && activo    === 'true')
                        || (filtroTipo === 'inactivos'  && activo    === 'false')
                        || (filtroTipo === 'bajostock'  && bajostock === 'true');

                    const visible = okTexto && okTipo;
                    tr.style.display = visible ? '' : 'none';

                    const detalle = tr.nextElementSibling;
                    if (detalle && detalle.classList.contains('collapse')) {
                        detalle.style.display = visible ? '' : 'none';
                    }

                    if (visible) visibles++;
                });

                contador.textContent = visibles === 1 ? '1 insumo' : visibles + ' insumos';
            }

            window.setPill = function (tipo) {
                filtroTipo = tipo;
                document.querySelectorAll('.pill-filtro').forEach(b => b.classList.remove('activo'));
                const map = { todos: 'pilTodos', activos: 'pilActivos', inactivos: 'pilInactivos', bajostock: 'pilBajoStock' };
                document.getElementById(map[tipo]).classList.add('activo');
                filtrar();
            };

            inputTexto.addEventListener('input', filtrar);

            filtrar();
        })();
    </script>
}
