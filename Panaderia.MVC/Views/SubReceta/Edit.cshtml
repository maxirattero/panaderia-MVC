@model Panaderia.Models.Entities.SubReceta
@using Panaderia.Models.Entities
@using System.Globalization
@{
    ViewData["Title"] = "Editar sub-receta";
    var insumosLista = (List<Insumo>)ViewBag.InsumosLista;
}

<div style="max-width: 820px;">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="display-6 fw-bold titulo-pagina mb-1">Editar sub-receta</h1>
            <p class="text-muted m-0">@Model.Nombre</p>
        </div>
        <button type="button"
                class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1"
                data-bs-toggle="modal" data-bs-target="#modalEliminar">
            <span class="material-symbols-outlined" style="font-size:1.1rem">delete</span>
            Eliminar
        </button>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="card card-custom p-4 mb-4">
            <div class="row g-4">
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label small fw-bold text-muted">Nombre <span class="text-danger">*</span></label>
                    <input asp-for="Nombre" type="text" class="form-control" required />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MargenSeguridad" class="form-label small fw-bold text-muted">Margen de seguridad</label>
                    <input asp-for="MargenSeguridad" type="number" class="form-control"
                           lang="en" step="0.01" min="0" max="1" placeholder="0.10" />
                    <div class="text-muted small mt-1">Ej: 0.10 = 10% extra para producción</div>
                </div>
                <div class="col-12">
                    <label asp-for="Notas" class="form-label small fw-bold text-muted">Notas</label>
                    <textarea asp-for="Notas" class="form-control" rows="2" placeholder="Opcional"></textarea>
                </div>
            </div>
        </div>

        <div class="card card-custom p-4 mb-4">
            <h6 class="fw-semibold mb-3">Ingredientes</h6>
            <div class="table-responsive mb-2">
                <table class="table table-sm align-middle mb-0">
                    <thead style="background-color: #cebaac; color: #281714;">
                        <tr>
                            <th style="min-width:200px;">Insumo</th>
                            <th style="width:110px;">Tipo</th>
                            <th style="width:150px;">Porcentaje / Cantidad</th>
                            <th style="width:50px;"></th>
                        </tr>
                    </thead>
                    <tbody id="detallesBody">
                        @{ int rowIndex = 0; }
                        @foreach (var det in Model.Detalles)
                        {
                            <tr data-insumo-id="@det.IdInsumo"
                                data-porcentaje="@(det.PorcentajePanadero?.ToString(CultureInfo.InvariantCulture) ?? "")"
                                data-cantidad-fija="@(det.CantidadFija?.ToString(CultureInfo.InvariantCulture) ?? "")">
                                <td>
                                    <select name="Detalles[@rowIndex].IdInsumo" class="form-select form-select-sm sel-insumo">
                                        <option value="">— Insumo —</option>
                                        @foreach (var ins in insumosLista)
                                        {
                                            <option value="@ins.Id" data-unidad-base="@((int)ins.UnidadBase)">@ins.Nombre</option>
                                        }
                                    </select>
                                </td>
                                <td><span class="tipo-label text-muted small">—</span></td>
                                <td>
                                    <input type="number" name="Detalles[@rowIndex].PorcentajePanadero"
                                           class="form-control form-control-sm inp-pct"
                                           lang="en" step="0.01" min="0" placeholder="%" />
                                    <input type="number" name="Detalles[@rowIndex].CantidadFija"
                                           class="form-control form-control-sm inp-fija"
                                           lang="en" step="0.001" min="0" placeholder="cant."
                                           style="display:none;" />
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-quitar" title="Quitar">✕</button>
                                </td>
                            </tr>
                            rowIndex++;
                        }
                    </tbody>
                </table>
            </div>
            <button type="button" id="btnAgregar"
                    class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                <span class="material-symbols-outlined" style="font-size:1rem">add</span>
                Agregar ingrediente
            </button>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-mv-primary">Guardar</button>
            <a asp-action="Index" class="btn btn-mv-secondary">Cancelar</a>
        </div>
    </form>
</div>

<template id="filaTemplate">
    <tr>
        <td>
            <select name="__INSUMO__" class="form-select form-select-sm sel-insumo">
                <option value="">— Insumo —</option>
                @foreach (var ins in insumosLista)
                {
                    <option value="@ins.Id" data-unidad-base="@((int)ins.UnidadBase)">@ins.Nombre</option>
                }
            </select>
        </td>
        <td><span class="tipo-label text-muted small">—</span></td>
        <td>
            <input type="number" name="__PCT__"
                   class="form-control form-control-sm inp-pct"
                   lang="en" step="0.01" min="0" placeholder="%" />
            <input type="number" name="__FIJA__"
                   class="form-control form-control-sm inp-fija"
                   lang="en" step="0.001" min="0" placeholder="cant."
                   style="display:none;" />
        </td>
        <td>
            <button type="button" class="btn btn-sm btn-outline-danger btn-quitar" title="Quitar">✕</button>
        </td>
    </tr>
</template>

<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Eliminar sub-receta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Confirmás que querés eliminar <strong>@Model.Nombre</strong>?</p>
                <p class="text-muted small mb-0">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const tbody      = document.getElementById('detallesBody');
    const tmpl       = document.getElementById('filaTemplate');
    const btnAgregar = document.getElementById('btnAgregar');

    function reindexar() {
        tbody.querySelectorAll('tr').forEach((tr, i) => {
            tr.querySelector('.sel-insumo').name = `Detalles[${i}].IdInsumo`;
            tr.querySelector('.inp-pct').name    = `Detalles[${i}].PorcentajePanadero`;
            tr.querySelector('.inp-fija').name   = `Detalles[${i}].CantidadFija`;
        });
    }

    function adaptarFila(tr, unidadBase) {
        const esFija = (unidadBase === 2);
        const pct    = tr.querySelector('.inp-pct');
        const fija   = tr.querySelector('.inp-fija');
        pct.style.display  = esFija ? 'none' : '';
        pct.disabled       = esFija;
        fija.style.display = esFija ? '' : 'none';
        fija.disabled      = !esFija;
        tr.querySelector('.tipo-label').textContent = esFija ? 'Cant. fija' : '% Panadero';
    }

    function bindFila(tr) {
        tr.querySelector('.sel-insumo').addEventListener('change', () => {
            const opt = tr.querySelector('.sel-insumo').options[tr.querySelector('.sel-insumo').selectedIndex];
            const ub  = parseInt(opt?.dataset?.unidadBase ?? '-1');
            adaptarFila(tr, ub);
            tr.querySelector('.inp-pct').value  = '';
            tr.querySelector('.inp-fija').value = '';
        });
        tr.querySelector('.btn-quitar').addEventListener('click', () => {
            tr.remove();
            reindexar();
        });
    }

    function agregarFila() {
        const frag = tmpl.content.cloneNode(true);
        const tr   = frag.querySelector('tr');
        bindFila(tr);
        tbody.appendChild(frag);
        reindexar();
    }

    tbody.querySelectorAll('tr').forEach(tr => {
        const id   = tr.dataset.insumoId;
        const pct  = tr.dataset.porcentaje;
        const fija = tr.dataset.cantidadFija;
        if (id) {
            const sel = tr.querySelector('.sel-insumo');
            sel.value = id;
            const opt = sel.options[sel.selectedIndex];
            const ub  = parseInt(opt?.dataset?.unidadBase ?? '-1');
            adaptarFila(tr, ub);
            if (pct)  tr.querySelector('.inp-pct').value  = pct;
            if (fija) tr.querySelector('.inp-fija').value = fija;
        }
        bindFila(tr);
    });

    btnAgregar.addEventListener('click', agregarFila);
    reindexar();
})();
</script>
}
