@model ReporteCajaFormViewModel
@using Panaderia.Models.Enums

@{
    ViewData["Title"] = "Editar movimiento";
}

<div style="max-width: 700px;">
    <div class="mb-4">
        <h1 class="display-6 fw-bold titulo-pagina mb-1">Editar movimiento</h1>
        <p class="text-muted">Modificá los datos del movimiento.</p>
    </div>

    @if (Model.IdPedido.HasValue)
    {
        <div class="alert alert-info mb-3">
            Movimiento generado por el Pedido #@Model.IdPedido — podés editarlo, el vínculo se conserva.
        </div>
    }

    <div class="card card-custom p-4 mb-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-4">
                <div class="col-md-6">
                    <label asp-for="Fecha" class="form-label small fw-bold text-muted">Fecha</label>
                    <input asp-for="Fecha" type="date" class="form-control" />
                    <span asp-validation-for="Fecha" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Categoria" class="form-label small fw-bold text-muted">Categoría</label>
                    <select asp-for="Categoria" asp-items="Html.GetEnumSelectList<CategoriaMovimiento>()"
                            class="form-select" id="categoriaSelect"></select>
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Tipo" class="form-label small fw-bold text-muted">Tipo</label>
                    <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoMovimiento>()"
                            class="form-select" id="tipoSelect"></select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Monto" class="form-label small fw-bold text-muted">Monto</label>
                    <input asp-for="Monto" type="number" step="0.01" lang="en" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Monto" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label small fw-bold text-muted">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>
                <div class="col-12" id="proveedorWrapper">
                    <label asp-for="IdProveedor" class="form-label small fw-bold text-muted">Proveedor</label>
                    <select asp-for="IdProveedor" asp-items="Model.Proveedores" class="form-select">
                        <option value="">— Ninguno —</option>
                    </select>
                </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-5 pt-4 border-top">
                <button type="submit" class="btn btn-mv-primary d-flex align-items-center justify-content-center gap-2">
                    <span class="material-symbols-outlined">save</span>Guardar cambios
                </button>
                <a asp-action="Index" class="btn btn-mv-primary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const catSelect = document.getElementById('categoriaSelect');
            const tipoSelect = document.getElementById('tipoSelect');
            const proveedorWrapper = document.getElementById('proveedorWrapper');

            function onCategoriaChange() {
                const cat = parseInt(catSelect.value);
                if (cat === 0) {
                    tipoSelect.value = '0';
                } else if (cat >= 1 && cat <= 3) {
                    tipoSelect.value = '1';
                }
                proveedorWrapper.style.display = cat === 1 ? '' : 'none';
            }

            catSelect.addEventListener('change', onCategoriaChange);
            onCategoriaChange();
        })();
    </script>
}
