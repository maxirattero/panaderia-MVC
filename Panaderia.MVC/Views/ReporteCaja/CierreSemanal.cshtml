@model Panaderia.MVC.Models.CierreSemanalViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Cierre semanal";
    var cultura = new CultureInfo("es-AR");
    var inv = CultureInfo.InvariantCulture;
    var gEstimadaStr = Model.GananciaEstimada.ToString("0.00", inv);
    var gFijaStr = Model.GananciaFija.ToString("0.00", inv);
    bool yaCerrado = ViewBag.YaCerrado == true;
    string semanaSeleccionada = ViewBag.SemanaSeleccionada;
    var semanas = ViewBag.Semanas as IEnumerable<dynamic>;
}

    <div class="mb-4">
        <h1 class="display-6 fw-bold titulo-pagina mb-1">Cierre semanal</h1>
        <p class="text-secondary m-0">
            Semana del @Model.InicioSemana.ToString("dd/MM") al @Model.FinSemana.ToString("dd/MM/yyyy")
        </p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Selector de semana *@
    <div class="card card-custom p-3 mb-4" style="max-width: 400px;">
        <label class="form-label small fw-bold text-muted mb-1">Seleccionar semana</label>
        <select class="form-select"
                onchange="window.location.href = '@Url.Action("CierreSemanal")' + '?inicioSemana=' + this.value">
            @if (semanas != null)
            {
                foreach (var s in semanas)
                {
                    if ((string)s.Valor == semanaSeleccionada)
                    {
                        <option value="@s.Valor" selected>@s.Label</option>
                    }
                    else
                    {
                        <option value="@s.Valor">@s.Label</option>
                    }
                }
            }
        </select>
    </div>

    @if (yaCerrado)
    {
        <div class="alert alert-info d-flex align-items-center gap-2" role="alert">
            <span class="material-symbols-outlined">check_circle</span>
            El cierre de esta semana ya fue registrado.
        </div>
    }
    else
    {
        @* Card 1: Resumen de movimientos *@
        <div class="card card-custom p-4 mb-4">
            <h5 class="fw-bold mb-3">Resumen de la semana</h5>
            <div class="row g-3">
                <div class="col-md-4 col-lg">
                    <div class="text-muted small mb-1">Ingresos</div>
                    <div class="fs-4 fw-bold text-success">@Model.TotalIngresos.ToString("C", cultura)</div>
                    <div class="text-muted small">Ventas y otros ingresos</div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="text-muted small mb-1">Egresos</div>
                    <div class="fs-4 fw-bold text-danger">@Model.TotalEgresos.ToString("C", cultura)</div>
                    <div class="text-muted small">Compras, gastos manuales</div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="text-muted small mb-1">Neto en caja</div>
                    <div class="fs-4 fw-bold @(Model.NetoSemana >= 0 ? "text-success" : "text-danger")">
                        @Model.NetoSemana.ToString("C", cultura)
                    </div>
                    <div class="text-muted small">Reserva + ganancia</div>
                </div>
                <div class="col-md-4 col-lg border-start-md">
                    <div class="text-muted small mb-1">Costo est. insumos</div>
                    <div class="fs-5 fw-semibold text-danger">@Model.CostoInsumos.ToString("C", cultura)</div>
                    <div class="text-muted small">Queda en caja como reserva</div>
                </div>
                <div class="col-md-4 col-lg">
                    <div class="text-muted small mb-1">Ganancia estimada</div>
                    <div class="fs-5 fw-semibold @(Model.GananciaEstimada >= 0 ? "text-success" : "text-danger")">
                        @Model.GananciaEstimada.ToString("C", cultura)
                    </div>
                    <div class="text-muted small">Lo que se retira</div>
                </div>
            </div>
        </div>

        @* Card 2: Desglose colapsable *@
        <div class="card card-custom p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Desglose por producto</h5>
                <button class="btn btn-sm btn-outline-secondary" type="button"
                        data-bs-toggle="collapse" data-bs-target="#collapseDesglose">
                    Ver desglose
                </button>
            </div>
            <div class="collapse mt-3" id="collapseDesglose">
                @if (!Model.DetallesCosto.Any())
                {
                    <p class="text-muted">No hay pedidos entregados esta semana con receta cargada.</p>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="text-end">Cantidad vendida</th>
                                <th class="text-end">Costo unitario</th>
                                <th class="text-end">Costo total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.DetallesCosto)
                            {
                                <tr>
                                    <td>@item.NombreProducto</td>
                                    <td class="text-end">@item.CantidadVendida</td>
                                    <td class="text-end">@item.CostoUnitario.ToString("C", cultura)</td>
                                    <td class="text-end fw-bold">@item.CostoTotal.ToString("C", cultura)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <p class="text-muted small mb-0">
                        Los costos se calculan con los precios actuales de los insumos.
                    </p>
                }
            </div>
        </div>

        @* Card 3: Registrar retiro *@
        <div class="card card-custom p-4" style="max-width: 540px;">
            <h5 class="fw-bold mb-3">Registrar retiro</h5>

            <div class="d-flex gap-2 mb-3">
                <button type="button" id="btnNeto"
                        class="btn btn-outline-secondary flex-fill"
                        onclick="usarMonto(@Model.NetoSemana.ToString("0.00", inv), 'btnNeto')">
                    Neto en caja<br />
                    <strong>@Model.NetoSemana.ToString("C", cultura)</strong>
                </button>
                <button type="button" id="btnEstimado"
                        class="btn btn-outline-secondary flex-fill active"
                        onclick="usarMonto(@gEstimadaStr, 'btnEstimado')">
                    Ganancia estimada<br />
                    <strong>@Model.GananciaEstimada.ToString("C", cultura)</strong>
                </button>
                <button type="button" id="btnFijo"
                        class="btn btn-outline-secondary flex-fill"
                        onclick="usarMonto(@gFijaStr, 'btnFijo')">
                    Fijo 70%<br />
                    <strong>@Model.GananciaFija.ToString("C", cultura)</strong>
                </button>
            </div>

            <form asp-action="RegistrarCierre" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="InicioSemana" value="@Model.InicioSemana.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="FinSemana"    value="@Model.FinSemana.ToString("yyyy-MM-dd")" />

                <div class="mb-3">
                    <label asp-for="MontoARetirar" class="form-label fw-semibold">Monto a retirar</label>
                    <input asp-for="MontoARetirar" type="number" class="form-control"
                           step="0.01" min="0.01" lang="en"
                           value="@Model.MontoARetirar.ToString("0.00", inv)" />
                    <span asp-validation-for="MontoARetirar" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Notas" class="form-label fw-semibold">
                        Notas <span class="text-muted fw-normal">(opcional)</span>
                    </label>
                    <input asp-for="Notas" type="text" class="form-control"
                           placeholder="Ej: semana con ventas altas" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit"
                            class="btn btn-mv-primary d-inline-flex align-items-center gap-2">
                        <span class="material-symbols-outlined">savings</span>Registrar recaudación
                    </button>
                    <a asp-controller="ReporteCaja" asp-action="Index"
                       class="btn btn-mv-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    }

@section Scripts {
<script>
function usarMonto(valor, btnId) {
    document.getElementById('MontoARetirar').value = valor.toFixed(2);
    ['btnNeto', 'btnEstimado', 'btnFijo'].forEach(function(id) {
        document.getElementById(id).classList.toggle('active', id === btnId);
    });
}
</script>
}
