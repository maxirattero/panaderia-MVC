@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model IEnumerable<Panaderia.Models.Entities.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="container-fluid p-4 p-md-5">
    <!-- Header Section -->
    <div class="row align-items-end mb-5 gy-4">
        <div class="col-md-7">
            <h1 class="display-6 fw-bold titulo-pagina mb-1">Productos</h1>
            <p class="text-secondary m-0">Administra el catálogo de productos de la panadería.</p>
        </div>
        <div class="col-md-5 text-md-end">
            <a asp-action="Create" class="btn btn-mv-primary d-inline-flex align-items-center gap-2 shadow">
                <span class="material-symbols-outlined">add_box</span>
                Agregar Nuevo Producto
            </a>
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="card-custom p-3 mb-4">
        <div class="row g-3">
            <div class="col-lg-6">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">
                        <span class="material-symbols-outlined text-secondary">filter_list</span>
                    </span>
                    <input class="form-control border-start-0 ps-0" placeholder="Filtrar por nombre..." type="text" />
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <select class="form-select">
                    <option>Todas las Masas</option>
                    <option>Semi-Integral</option>
                    <option>Integral</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card-custom overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-custom table-hover m-0">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Formato / Tamaño</th>
                        <th class="text-end">Precio Final</th>
                        <th class="text-end">Precio Reventa</th>
                        <th class="text-center">Stock</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle" style="background-color: var(--mv-surface-variant); color: var(--mv-primary-dark);">
                                        @producto.Nombre.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold">@producto.Nombre</div>
                                        <small class="text-secondary">
                                            @(producto.Variedad.HasValue ? $"{producto.Masa} · {producto.Variedad}" : producto.Masa.ToString())
                                        </small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-secondary">@producto.Categoria?.Nombre</span>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1 small text-secondary">
                                    <span class="d-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined fs-6">deployed_code</span>
                                        @(producto.Formato?.Descripcion ?? "-")
                                    </span>
                                    <span class="d-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined fs-6">straighten</span>
                                        @(producto.Tamano?.Descripcion ?? "-")
                                    </span>
                                </div>
                            </td>
                            <td class="text-end fw-bold">
                                $@producto.PrecioFinal.ToString("N2")
                            </td>
                            <td class="text-end fw-bold">
                                $@producto.PrecioReventa.ToString("N2")
                            </td>
                            <td class="text-center">
                                @producto.Stock
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-primary" title="Ver Detalles">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@producto.Id" class="btn btn-sm btn-outline-success" title="Editar">
                                        <span class="material-symbols-outlined">edit</span>
                                    </a>
                                    <a asp-controller="Receta" asp-action="Editar"
                                       asp-route-idProducto="@producto.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                       title="Receta">
                                        <span class="material-symbols-outlined">menu_book</span>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Eliminar"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@producto.Id"
                                            data-nombre="@producto.Nombre"
                                            data-delete-url="@Url.Action("Delete", "Producto", new { id = producto.Id })"
                                            data-token="@Antiforgery.GetAndStoreTokens(Context).RequestToken">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>