@model Panaderia.Models.Entities.Producto
@using Panaderia.Models.Enums

@{
    ViewData["Title"] = "Nuevo Producto";
}

<!-- Heading -->
<div class="mb-4">
    <h2 class="font-literata fw-bold titulo-pagina">Agregar Nuevo Producto</h2>
    <p class="text-muted">Completa la información para registrar un nuevo producto.</p>
</div>

<div class="card card-custom p-4 mb-4">
    <form asp-action="Create">
        <div class="row g-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Nombre -->
            <div class="col-md-6">
                <label asp-for="Nombre" class="form-label small fw-bold text-muted">Nombre <span class="text-danger">*</span></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. Pan Semi-Integral Semillas Molde" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- Categoría -->
            <div class="col-md-6">
                <label asp-for="IdCategoria" class="form-label small fw-bold text-muted">Categoría <span class="text-danger">*</span></label>
                <select asp-for="IdCategoria" asp-items="ViewBag.Categorias" class="form-select">
                    <option value="">-- Seleccionar categoría --</option>
                </select>
                <span asp-validation-for="IdCategoria" class="text-danger"></span>
            </div>

            <!-- Masa -->
            <div class="col-md-6">
                <label asp-for="Masa" class="form-label small fw-bold text-muted">Masa <span class="text-danger">*</span></label>
                <select asp-for="Masa" asp-items="Html.GetEnumSelectList<Masa>()" class="form-select">
                    <option value="">-- Seleccionar masa --</option>
                </select>
                <span asp-validation-for="Masa" class="text-danger"></span>
            </div>

            <!-- Variedad -->
            <div class="col-md-6">
                <label asp-for="Variedad" class="form-label small fw-bold text-muted">Variedad</label>
                <select asp-for="Variedad" asp-items="Html.GetEnumSelectList<Variedad>()" class="form-select">
                    <option value="">-- Sin variedad --</option>
                </select>
                <span asp-validation-for="Variedad" class="text-danger"></span>
            </div>

            <!-- Formato -->
            <div class="col-md-6">
                <label asp-for="IdFormato" class="form-label small fw-bold text-muted">Formato</label>
                <select asp-for="IdFormato" asp-items="ViewBag.Formatos" class="form-select">
                    <option value="">-- Sin formato --</option>
                </select>
                <span asp-validation-for="IdFormato" class="text-danger"></span>
            </div>

            <!-- Tamaño -->
            <div class="col-md-6">
                <label asp-for="IdTamano" class="form-label small fw-bold text-muted">Tamaño</label>
                <select asp-for="IdTamano" asp-items="ViewBag.Tamanos" class="form-select">
                    <option value="">-- Sin tamaño --</option>
                </select>
                <span asp-validation-for="IdTamano" class="text-danger"></span>
            </div>

            <!-- Precio Final -->
            <div class="col-md-6">
                <label asp-for="PrecioFinal" class="form-label small fw-bold text-muted">Precio Final <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="PrecioFinal" class="form-control" type="number" lang="en" step="0.01" min="0" placeholder="0.00" />
                </div>
                <span asp-validation-for="PrecioFinal" class="text-danger"></span>
            </div>

            <!-- Precio Reventa -->
            <div class="col-md-6">
                <label asp-for="PrecioReventa" class="form-label small fw-bold text-muted">Precio Reventa <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="PrecioReventa" class="form-control" type="number" lang="en" step="0.01" min="0" placeholder="0.00" />
                </div>
                <span asp-validation-for="PrecioReventa" class="text-danger"></span>
            </div>

            <!-- Stock -->
            <div class="col-md-6">
                <label asp-for="Stock" class="form-label small fw-bold text-muted">Stock</label>
                <input asp-for="Stock" class="form-control" type="number" min="0" placeholder="0" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <!-- Imagen URL -->
            <div class="col-md-6">
                <label asp-for="ImagenURL" class="form-label small fw-bold text-muted">URL de Imagen</label>
                <input asp-for="ImagenURL" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ImagenURL" class="text-danger"></span>
            </div>
        </div>

        @{ var costoUnidad = (decimal)(ViewBag.CostoUnidad ?? 0m); }
        @if (costoUnidad > 0)
        {
            <div class="mt-3 p-3 rounded" style="background-color: #f5efe9;">
                <div class="small text-muted mb-3">
                    Costo por unidad (receta):
                    <strong data-costo="@costoUnidad.ToString("F10", System.Globalization.CultureInfo.InvariantCulture)">
                        $@costoUnidad.ToString("N2")
                    </strong>
                </div>

                <div class="row g-2 align-items-center mb-2">
                    <div class="col-sm-2">
                        <span class="small text-muted fw-semibold">Precio Final</span>
                    </div>
                    <div class="col-sm-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">CMV%</span>
                            <input type="number" id="cmvFinal" class="form-control"
                                   lang="en" step="0.01" min="0" max="100" />
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Markup%</span>
                            <input type="number" id="markupFinal" class="form-control"
                                   lang="en" step="0.01" min="0" />
                        </div>
                    </div>
                </div>

                <div class="row g-2 align-items-center">
                    <div class="col-sm-2">
                        <span class="small text-muted fw-semibold">Precio Reventa</span>
                    </div>
                    <div class="col-sm-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">CMV%</span>
                            <input type="number" id="cmvReventa" class="form-control"
                                   lang="en" step="0.01" min="0" max="100" />
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Markup%</span>
                            <input type="number" id="markupReventa" class="form-control"
                                   lang="en" step="0.01" min="0" />
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Action Buttons -->
        <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-5 pt-4 border-top">
            <button type="submit" class="btn btn-mv-primary d-flex align-items-center justify-content-center gap-2">
                <span class="material-symbols-outlined">save</span>Guardar
            </button>
            <a asp-action="Index" class="btn btn-mv-tertiary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    const costoEl = document.querySelector('[data-costo]');
    if (!costoEl) return;

    const costo = parseFloat(costoEl.dataset.costo) || 0;
    if (costo <= 0) return;

    const precioFinal   = document.getElementById('PrecioFinal');
    const precioReventa = document.getElementById('PrecioReventa');
    const cmvFinal      = document.getElementById('cmvFinal');
    const markupFinal   = document.getElementById('markupFinal');
    const cmvReventa    = document.getElementById('cmvReventa');
    const markupReventa = document.getElementById('markupReventa');

    function calcularDesde(fuente, precioEl, cmvEl, markupEl) {
        const precio = parseFloat(precioEl.value) || 0;
        const cmv    = parseFloat(cmvEl.value)    || 0;
        const markup = parseFloat(markupEl.value) || 0;

        if (fuente === 'precio' && precio > 0) {
            cmvEl.value    = (costo / precio * 100).toFixed(2);
            markupEl.value = ((precio - costo) / costo * 100).toFixed(2);
        } else if (fuente === 'cmv' && cmv > 0) {
            const p        = costo / (cmv / 100);
            precioEl.value = p.toFixed(2);
            markupEl.value = ((p - costo) / costo * 100).toFixed(2);
        } else if (fuente === 'markup') {
            const p        = costo * (1 + markup / 100);
            precioEl.value = p.toFixed(2);
            cmvEl.value    = (costo / p * 100).toFixed(2);
        }
    }

    precioFinal.addEventListener('input',
        () => calcularDesde('precio', precioFinal, cmvFinal, markupFinal));
    cmvFinal.addEventListener('input',
        () => calcularDesde('cmv', precioFinal, cmvFinal, markupFinal));
    markupFinal.addEventListener('input',
        () => calcularDesde('markup', precioFinal, cmvFinal, markupFinal));

    precioReventa.addEventListener('input',
        () => calcularDesde('precio', precioReventa, cmvReventa, markupReventa));
    cmvReventa.addEventListener('input',
        () => calcularDesde('cmv', precioReventa, cmvReventa, markupReventa));
    markupReventa.addEventListener('input',
        () => calcularDesde('markup', precioReventa, cmvReventa, markupReventa));

    if (parseFloat(precioFinal.value) > 0)
        calcularDesde('precio', precioFinal, cmvFinal, markupFinal);
    if (parseFloat(precioReventa.value) > 0)
        calcularDesde('precio', precioReventa, cmvReventa, markupReventa);
})();
</script>
}