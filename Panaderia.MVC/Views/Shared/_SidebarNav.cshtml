</div>
<nav class="flex-grow-1">
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
       asp-controller="Home" asp-action="Index">
        <span class="material-symbols-outlined">dashboard</span>
        Dashboard
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pedido" ? "active" : "")"
       asp-controller="Pedido" asp-action="Index">
        <span class="material-symbols-outlined">shopping_cart</span>
        Pedidos
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cliente" ? "active" : "")"
       asp-controller="Cliente" asp-action="Index">
        <span class="material-symbols-outlined">groups</span>
        Clientes
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Producto" ? "active" : "")"
       asp-controller="Producto" asp-action="Index">
        <span class="material-symbols-outlined">inventory_2</span>
        Productos
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Proveedor" ? "active" : "")"
       asp-controller="Proveedor" asp-action="Index">
        <span class="material-symbols-outlined">local_shipping</span>
        Proveedores
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Insumo" ? "active" : "")"
       asp-controller="Insumo" asp-action="Index">
        <span class="material-symbols-outlined">inventory_2</span>
        Insumos
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Compra" ? "active" : "")"
       asp-controller="Compra" asp-action="Index">
        <span class="material-symbols-outlined">receipt_long</span>
        Compras
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "SubReceta" ? "active" : "")"
       asp-controller="SubReceta" asp-action="Index">
        <span class="material-symbols-outlined">science</span>
        Sub-recetas
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Configuracion" ? "active" : "")"
       asp-controller="Configuracion" asp-action="Index">
        <span class="material-symbols-outlined">settings</span>
        Configuración
    </a>
    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReporteCaja" ? "active" : "")"
       asp-controller="ReporteCaja" asp-action="Index">
        <span class="material-symbols-outlined">account_balance_wallet</span>
        Caja
    </a>
</nav>
<div class="mt-auto border-top pt-4">
    <div class="mb-3 px-3">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="material-symbols-outlined" style="font-size:1.2rem; color: var(--mv-secondary);">account_circle</span>
            <span class="small text-muted text-truncate" style="max-width: 160px;">@User.Identity?.Name</span>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-1">
                <span class="material-symbols-outlined" style="font-size:1rem">logout</span>
                Cerrar sesión
            </button>
        </form>
    </div>
    <button class="btn btn-mv-primary w-100 d-flex align-items-center justify-content-center gap-2">
        <span class="material-symbols-outlined">add</span>
        Nuevo Pedido
    </button>
</div>
