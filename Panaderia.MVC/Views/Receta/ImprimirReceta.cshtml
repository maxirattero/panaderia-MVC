@model Panaderia.MVC.Models.ImprimirRecetaViewModel
@using Panaderia.Models.Enums
@using System.Globalization
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Receta: @Model.Receta.Producto.NombreVisible</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { font-size: 13px; }
        .grid-recetas {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .receta-card {
            border: 1px solid #ccc;
            padding: 10px;
            border-radius: 4px;
            font-size: 12px;
            break-inside: avoid;
        }
        @@media print {
            .no-print { display: none !important; }
            .grid-recetas {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }
            .receta-card { break-inside: avoid; }
        }
    </style>
</head>
<body onload="window.print()">
    <button onclick="window.print()" class="no-print btn btn-sm btn-secondary mb-3">Imprimir</button>

    <div class="receta-card" style="max-width: 48%;">
    <h4>Receta: @Model.Receta.Producto.NombreVisible</h4>
    <p>
        Cantidad a producir: <strong>@Model.CantidadUnidades unidades</strong>
        (@Model.VecesReceta.ToString("0.##") veces la receta base de @Model.Receta.TamanioLote unidades)
    </p>

    <table class="mb-3">
        <thead>
            <tr>
                <th>Ingrediente</th>
                <th>Unidad</th>
                <th>Cantidad</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var det in Model.Receta.Detalles)
            {
                var unidadStr = det.Insumo.UnidadBase switch
                {
                    UnidadMedida.Gramos     => "g",
                    UnidadMedida.Mililitros => "ml",
                    UnidadMedida.Unidades   => "u",
                    _                       => det.Insumo.UnidadBase.ToString()
                };
                decimal cantidadDet = 0m;
                if (det.PorcentajePanadero.HasValue && Model.Receta.SumaPorcentajes > 0)
                    cantidadDet = (Model.Receta.TamanioLote * Model.Receta.PesoUnitario
                                   / Model.Receta.SumaPorcentajes)
                                  * det.PorcentajePanadero.Value * Model.VecesReceta;
                else if (det.CantidadFija.HasValue)
                    cantidadDet = det.CantidadFija.Value * Model.CantidadUnidades;
                <tr>
                    <td>@det.Insumo.Nombre</td>
                    <td>@unidadStr</td>
                    <td>@cantidadDet.ToString("0.###", CultureInfo.InvariantCulture)</td>
                </tr>
            }
        </tbody>
    </table>

    <p>
        <strong>Peso masa total:</strong>
        @((Model.Receta.TamanioLote * Model.Receta.PesoUnitario * Model.VecesReceta)
            .ToString("0.###", CultureInfo.InvariantCulture)) g
    </p>
    <p><strong>Rinde:</strong> @Model.CantidadUnidades unidades</p>
    </div>
</body>
</html>
