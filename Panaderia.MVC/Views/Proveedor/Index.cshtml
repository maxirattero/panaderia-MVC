@model IEnumerable<Panaderia.Models.Entities.Proveedor>

@{
    ViewData["Title"] = "Proveedores";
}

<h2>Proveedores</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Nuevo Proveedor</a>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Contacto</th>
            <th>Telefono</th>
            <th>Email</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var proveedor in Model)
        {
            <tr>
                <td>@proveedor.Nombre</td>
                @* completá las demás columnas *@
                <td>
                    @* botones de acciones *@
                </td>
            </tr>
        }
    </tbody>
</table>