@model IEnumerable<Panaderia.Models.Entities.CompraProveedor>

@{
    ViewData["Title"] = "Compras";
    var cultura = new System.Globalization.CultureInfo("es-AR");
}
    <div class="row align-items-end mb-5 gy-4">
        <div class="col-md-7">
            <h1 class="display-6 fw-bold titulo-pagina mb-1">Compras</h1>
            <p class="text-secondary m-0">Registrá las compras a proveedores y actualizá el stock automáticamente.</p>
        </div>
        <div class="col-md-5 text-md-end">
            <a asp-action="Create" class="btn btn-mv-primary d-inline-flex align-items-center gap-2 shadow">
                <span class="material-symbols-outlined">add</span>
                Registrar compra
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card card-custom overflow-hidden">
        <div class="table-responsive">
            <table class="table table-custom table-hover m-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Proveedor</th>
                        <th>Nº Factura</th>
                        <th>Monto total</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No hay compras registradas.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@c.Proveedor.Nombre</td>
                                <td class="text-secondary">@(c.NumeroFactura ?? "—")</td>
                                <td>@c.MontoTotal.ToString("C", cultura)</td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@c.Id"
                                           class="btn btn-sm btn-outline-primary" title="Ver detalle">
                                            <span class="material-symbols-outlined">visibility</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
