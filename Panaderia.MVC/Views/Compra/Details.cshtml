@model Panaderia.Models.Entities.CompraProveedor

@{
    ViewData["Title"] = "Detalle de compra";
    var cultura = new System.Globalization.CultureInfo("es-AR");
}

<div class="container-fluid p-4 p-md-5" style="max-width: 800px;">
    <div class="mb-4">
        <h1 class="display-6 fw-bold titulo-pagina mb-1">Detalle de compra</h1>
    </div>

    <div class="card card-custom p-4 mb-4">
        <div class="row g-3">
            <div class="col-sm-6">
                <div class="small fw-bold text-muted mb-1">Proveedor</div>
                <div>@Model.Proveedor.Nombre</div>
            </div>
            <div class="col-sm-6">
                <div class="small fw-bold text-muted mb-1">Fecha</div>
                <div>@Model.Fecha.ToString("dd/MM/yyyy")</div>
            </div>
            <div class="col-sm-6">
                <div class="small fw-bold text-muted mb-1">Nº Factura</div>
                <div>@(Model.NumeroFactura ?? "—")</div>
            </div>
            <div class="col-sm-6">
                <div class="small fw-bold text-muted mb-1">Monto total</div>
                <div class="fw-bold fs-5">@Model.MontoTotal.ToString("C", cultura)</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Notas))
            {
                <div class="col-12">
                    <div class="small fw-bold text-muted mb-1">Notas</div>
                    <div>@Model.Notas</div>
                </div>
            }
        </div>
    </div>

    <div class="card card-custom overflow-hidden mb-4">
        <div class="table-responsive">
            <table class="table table-custom m-0">
                <thead>
                    <tr>
                        <th>Insumo</th>
                        <th>Unidad de compra</th>
                        <th>Cantidad</th>
                        <th>Precio unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Detalles)
                    {
                        <tr>
                            <td>@d.Insumo.Nombre</td>
                            <td>@d.UnidadCompra.Nombre</td>
                            <td>@d.Cantidad.ToString("0.###")</td>
                            <td>@d.PrecioUnitario.ToString("C", cultura)</td>
                            <td>@d.Subtotal.ToString("C", cultura)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-mv-secondary d-inline-flex align-items-center gap-2">
        <span class="material-symbols-outlined">arrow_back</span>Volver
    </a>
</div>
